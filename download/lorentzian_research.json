    "html": "<html lang=\"en\" dir=\"ltr\"><head>\n    <meta charset=\"utf-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"robots\" content=\"noindex\">\n    <title>Just a moment...</title>\n    <style>\n        /* Reset and base styles */\n        * {\n            box-sizing: border-box;\n        }\n        \n        body, p, h1, h2 {\n            margin: 0;\n            padding: 0;\n            outline: none;\n        }\n        \n        a, a:hover {\n            text-decoration: none;\n            cursor: pointer;\n        }\n        \n        body {\n            height: 100vh;\n            color: #39393A;\n            font-family: 'Inter', Arial, sans-serif;\n            font-size: 16px;\n            line-height: 1.5;\n            text-align: center;\n            word-wrap: break-word;\n            text-rendering: optimizeLegibility;\n            -webkit-font-smoothing: antialiased;\n            background: #FFFFFF;\n        }\n        \n        /* Header styles */\n        .error-navbar {\n            box-sizing: border-box;\n            display: flex;\n            flex-direction: row;\n            align-items: center;\n            padding: 0px 20px;\n            margin: 0;\n            width: 100%;\n            height: 64px;\n            background: #F6F6F6;\n            border-bottom: 1px solid #E8E8E8;\n            position: relative;\n            z-index: 10;\n        }\n        \n        .logo-container {\n            display: flex;\n            flex-direction: row;\n            align-items: center;\n            padding: 0px;\n            gap: 32px;\n            width: 149.09px;\n            height: 20px;\n            flex: none;\n            order: 0;\n            flex-grow: 0;\n        }\n        \n        .logo-link {\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            padding: 0px;\n            gap: 10px;\n            width: 149.09px;\n            height: 20px;\n            flex: none;\n            order: 0;\n            flex-grow: 0;\n        }\n        \n        .error-navbar-logo {\n            width: 149.09px;\n            height: 20px;\n            flex: none;\n            order: 0;\n            flex-grow: 0;\n        }\n        \n        /* Main container */\n        .main {\n            display: flex;\n            flex-direction: column;\n            min-height: calc(100vh - 64px);\n            justify-content: center;\n            align-items: center;\n            background: #F6F6F6;\n            padding: 20px;\n        }\n\n        /* Challenge content container */\n        .challenge-content {\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            width: 100%;\n            width: 576px;\n            margin: 0 auto;\n            gap: 16px;\n        }\n\n        /* Warning icon */\n        .challenge-icon {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            width: 96px;\n            height: 96px;\n        }\n\n        .challenge-icon svg {\n            width: 96px;\n            height: 96px;\n        }\n\n        /* Heading */\n        .challenge-heading h1 {\n            font-family: 'Inter', Arial, sans-serif;\n            font-weight: 600;\n            font-size: 22px;\n            line-height: 1.3;\n            color: #39393A;\n            margin: 0;\n        }\n\n        /* Main message */\n        .challenge-message p {\n            font-family: 'Inter', Arial, sans-serif;\n            font-weight: 400;\n            font-size: 16px;\n            line-height: 1.5;\n            color: #39393A;\n            margin: 0;\n            max-width: 500px;\n        }\n\n        /* CAPTCHA container */\n        .challenge-captcha {\n            width: 100%;\n            max-width: 576px;\n            min-height: 64px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .challenge-captcha ul {\n            list-style: none;\n            padding-left: 0;\n        }\n\n        /* Login promo section */\n        .challenge-login-promo {\n            width: 100%;\n            max-width: 500px;\n        }\n\n        .login-promo-content {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 16px;\n            padding: 16px 0px;\n        }\n\n        .login-promo-main {\n            display: flex;\n            align-items: center;\n            gap: 16px;\n            width: 100%;\n            justify-content: center;\n        }\n\n        .login-promo-text-section {\n            flex: 1;\n            text-align: center;\n        }\n\n        .login-promo-title {\n            font-family: 'Inter', Arial, sans-serif;\n            font-weight: 600;\n            font-size: 16px;\n            color: #39393A;\n            margin: 0 0 8px 0;\n        }\n\n        .login-promo-text {\n            font-family: 'Inter', Arial, sans-serif;\n            font-weight: 400;\n            font-size: 16px;\n            line-height: 1.5;\n            color: #39393A;\n            margin: 0;\n        }\n\n        /* Button container */\n        .login-buttons {\n            display: flex;\n            flex-direction: row;\n            justify-content: center;\n            align-items: flex-start;\n            padding: 0px;\n            gap: 8px;\n            margin-top: 10px;\n        }\n\n        /* Button styles */\n        .btn {\n            box-sizing: border-box;\n            display: flex;\n            flex-direction: row;\n            justify-content: center;\n            align-items: center;\n            padding: 0px 16px;\n            gap: 4px;\n            height: 32px;\n            border-radius: 16px;\n            font-family: 'Inter', Arial, sans-serif;\n            font-style: normal;\n            font-weight: 400;\n            font-size: 14px;\n            line-height: 20px;\n            text-decoration: none;\n            cursor: pointer;\n            transition: all 0.2s ease;\n            flex: none;\n            flex-grow: 0;\n            white-space: nowrap;\n        }\n\n        .btn-primary {\n            background: #006DD9;\n            color: #FFFFFF;\n            border: none;\n        }\n\n        .btn-primary:hover {\n            background: #0056B3;\n            color: #FFFFFF;\n        }\n\n        .btn-secondary {\n            background: transparent;\n            color: #006DD9;\n            border: 1px solid #006DD9;\n        }\n\n        .btn-secondary:hover {\n            background: #F0F7FF;\n            color: #006DD9;\n            border: 1px solid #006DD9;\n        }\n\n        /* Additional info */\n        .challenge-additional-info {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 8px;\n        }\n\n        .challenge-additional-info p {\n            font-family: 'Inter', Arial, sans-serif;\n            font-weight: 400;\n            font-size: 14px;\n            line-height: 1.4;\n            color: #39393A;\n            margin: 0;\n        }\n\n        /* Footer */\n        .challenge-footer {\n        }\n\n        .challenge-footer p {\n            font-family: 'Inter', Arial, sans-serif;\n            font-weight: 400;\n            font-size: 12px;\n            line-height: 1.3;\n            color: #6F6F71;\n            margin: 0;\n        }\n\n        /* Mobile responsive */\n        @media (max-width: 767px) {\n            .error-navbar {\n                padding: 0px 16px;\n            }\n            \n            .main {\n                padding: 20px;\n                min-height: calc(100vh - 64px);\n            }\n            \n            .challenge-content {\n                width: auto;\n                max-width: 576px;\n            }\n            \n            .challenge-heading h1 {\n                font-size: 22px;\n            }\n            \n            .challenge-message p,\n            .login-promo-text {\n                font-size: 16px;\n            }\n\n            .challenge-icon {\n                width: 96px;\n                height: 96px;\n            }\n            \n            .challenge-icon svg {\n                width: 96px;\n                height: 96px;\n            }\n\n            .login-promo-main {\n                flex-direction: column;\n                gap: 16px;\n            }\n\n            .login-promo-text-section {\n                order: 2;\n            }\n            \n            .login-buttons {\n                flex-direction: column;\n                align-items: stretch;\n                gap: 8px;\n                width: 100%;\n            }\n            \n            .btn {\n                min-width: 140px;\n                padding: 0px 20px;\n            }\n            \n            .challenge-captcha {\n                min-height: 64px;\n            }\n        }\n    </style>\n<meta http-equiv=\"refresh\" content=\"360\">\n<script src=\"/cdn-cgi/challenge-platform/h/g/orchestrate/chl_page/v1?ray=9d50829b8f72a36e\"></script><script src=\"https://challenges.cloudflare.com/turnstile/v0/g/ea2d291c0fdc/api.js?onload=MNurp8&amp;render=explicit\" async=\"\" defer=\"\" crossorigin=\"anonymous\"></script></head>\n<body>\n<div class=\"error-navbar\">\n    <div class=\"logo-container\">\n        <a href=\"https://www.researchgate.net\" class=\"logo-link\">\n            <svg class=\"error-navbar-logo\" width=\"150\" height=\"20\" viewBox=\"0 0 150 20\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                <path d=\"M86.3714 18.7355L85.4769 18.8396L85.5763 19.4642C86.272 19.3601 87.2659 19.3601 88.2599 19.3601C88.801 19.3601 89.3716 19.3909 89.8915 19.